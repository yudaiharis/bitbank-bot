# コピーして .env を作成してください（git には含まれません）
# cp .env.example .env

# GitHub Personal Access Token (read-only / repo スコープ)
# https://github.com/settings/tokens/new?scopes=repo
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# リポジトリ名（owner/repo 形式）
GITHUB_REPO=yudaiharis/bitbank-bot

# Slack 通知（任意）
SLACK_WEBHOOK_URL=

# Cloudflare Quick Tunnel はドメイン・トークン不要
# 起動時に *.trycloudflare.com の URL が自動発行され Slack に通知されます
